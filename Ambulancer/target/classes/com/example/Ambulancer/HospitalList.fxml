<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.Font?>
<?import javafx.scene.image.ImageView?>
<?import javafx.scene.image.Image?>
<?import javafx.scene.shape.Circle?>
<BorderPane maxHeight="Infinity" maxWidth="Infinity" prefHeight="800" prefWidth="1200"
            style="-fx-background-color: linear-gradient(to bottom right, #f8fafc, #e2e8f0);"
            xmlns="http://javafx.com/javafx/25"
            xmlns:fx="http://javafx.com/fxml/1"
            fx:controller="com.example.Ambulancer.controllers.HospitalList">

    <!-- TOP BAR - Enhanced with glass morphism -->
    <top>
        <HBox alignment="CENTER_LEFT" spacing="20" style="-fx-background-color: rgba(255, 255, 255, 0.9);
              -fx-padding: 20 30; -fx-background-radius: 0 0 20 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.08), 15, 0, 0, 5);">

            <!-- Back Button with hover effect -->
            <StackPane id="back-btn" fx:id="Abackbtn" onMouseClicked="#Backclicked" style="-fx-cursor: hand"
                       styleClass="back-button-stackpane">
                <children>
                    <ImageView fitHeight="38" fitWidth="38" preserveRatio="true">
                        <image>
                            <Image url="@images/Dlback.png" />
                        </image>
                    </ImageView>
                </children>
            </StackPane>

            <!-- Title with gradient -->
            <Label text="🏥 Hospital Directory"
                   style="-fx-font-size: 28px; -fx-font-weight: 800; -fx-text-fill: linear-gradient(to right, #2c3e50, #3498db);
                          -fx-effect: dropshadow(gaussian, rgba(52, 152, 219, 0.3), 5, 0, 2, 2);"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Search field with modern styling -->
            <HBox alignment="CENTER" spacing="10">
                <TextField fx:id="searchField" promptText="🔍 Search hospitals by name or branch..."
                           style="-fx-pref-width: 320; -fx-pref-height: 42; -fx-font-size: 14px;
                                  -fx-background-color: white; -fx-background-radius: 10;
                                  -fx-border-color: #e2e8f0; -fx-border-radius: 10; -fx-border-width: 2;
                                  -fx-padding: 0 15; -fx-prompt-text-fill: #94a3b8;"/>

                <!-- Refresh button with icon -->
                <Button onAction="#refreshHospitals" text="🔄"
                        style="-fx-background-color: #3498db; -fx-text-fill: white; -fx-font-size: 16px;
                               -fx-font-weight: bold; -fx-padding: 12; -fx-background-radius: 10;
                               -fx-min-width: 42; -fx-min-height: 42; -fx-cursor: hand;"
                        styleClass="refresh-button"/>

                <!-- Emergency button with pulse animation -->
                <Button onAction="#reportEmergency" text="🚨 Emergency"
                        style="-fx-background-color: linear-gradient(to right, #e74c3c, #c0392b);
                               -fx-text-fill: white; -fx-font-weight: bold; -fx-font-size: 14px;
                               -fx-padding: 12 25; -fx-background-radius: 10; -fx-cursor: hand;
                               -fx-effect: dropshadow(gaussian, rgba(231, 76, 60, 0.4), 10, 0, 0, 3);"
                        styleClass="emergency-btn"/>
            </HBox>
        </HBox>
    </top>

    <!-- MAIN CONTENT -->
    <center>
        <VBox spacing="25" style="-fx-padding: 30; -fx-background-color: transparent;">
            <!-- Results Header with stats -->
            <HBox alignment="CENTER_LEFT" spacing="15">
                <VBox spacing="5">
                    <Label fx:id="resultsCountLabel" text="Loading hospitals..."
                           style="-fx-font-size: 18px; -fx-font-weight: 700; -fx-text-fill: #2c3e50;"/>
                    <Label text="Real-time emergency response system"
                           style="-fx-font-size: 12px; -fx-text-fill: #64748b;"/>
                </VBox>

                <Region HBox.hgrow="ALWAYS"/>

                <!-- Loading indicator with modern style -->
                <VBox alignment="CENTER" spacing="5">
                    <ProgressIndicator fx:id="loadingIndicator" visible="false"
                                       progress="0"
                                       style="-fx-progress-color: #3498db; -fx-accent: #3498db;"/>
                    <Label text="Loading..." visible="false" fx:id="loadingText"
                           style="-fx-font-size: 11px; -fx-text-fill: #64748b;"/>
                </VBox>
            </HBox>

            <!-- Hospitals Grid Container -->
            <ScrollPane fitToWidth="true" hbarPolicy="NEVER"
                        style="-fx-background-color: transparent; -fx-border-color: transparent; -fx-padding: 0;">
                <VBox fx:id="hospitalsContainer" spacing="20">
                    <!-- Hospitals will be loaded here dynamically -->
                </VBox>
            </ScrollPane>
        </VBox>
    </center>

    <!-- BOTTOM BAR - Status bar -->
    <bottom>
        <HBox alignment="CENTER" style="-fx-background-color: rgba(30, 41, 59, 0.95); -fx-padding: 15 30;
              -fx-background-radius: 20 20 0 0;">
            <!-- Connection status -->
            <HBox spacing="10" alignment="CENTER_LEFT">
                <Circle radius="4" fill="#10b981"/>
                <Label text="Connected to Emergency Network"
                       style="-fx-text-fill: #e2e8f0; -fx-font-size: 13px;"/>
            </HBox>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- Last updated -->
            <Label fx:id="lastUpdatedLabel" text="Last updated: --:--"
                   style="-fx-text-fill: #94a3b8; -fx-font-size: 13px;"/>

            <Region HBox.hgrow="ALWAYS"/>

            <!-- System status -->
            <HBox spacing="5" alignment="CENTER_RIGHT">
                <Label text="🚑" style="-fx-font-size: 16px;"/>
                <Label text="Emergency Response System v2.1"
                       style="-fx-text-fill: #cbd5e1; -fx-font-size: 13px;"/>
            </HBox>
        </HBox>
    </bottom>

</BorderPane>